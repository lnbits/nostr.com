{
  "name": "nostr-social",
  "version": "0.1.0",
  "description": "A mobile-ready Nostr social client.",
  "author": "LNbits",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "svelte-kit sync && vite --host 0.0.0.0",
    "icons": "node scripts/generate-icons.cjs",
    "build": "node scripts/generate-sitemap.cjs && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop:win": "npm run icons && npm run build && electron-builder --win nsis --x64 --publish never",
    "desktop:mac": "npm run icons && npm run build && electron-builder --mac dmg --x64 --arm64 --publish never",
    "desktop:mac:x64": "npm run icons && npm run build && electron-builder --mac dmg --x64 --publish never",
    "desktop:mac:arm64": "npm run icons && npm run build && electron-builder --mac dmg --arm64 --publish never",
    "desktop:linux": "npm run icons && npm run build && electron-builder --linux AppImage --x64 --publish never",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run icons && npm run build && cap sync && npm run icons"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/status-bar": "^7.0.3",
    "@fiatjaf/promenade-trusted-dealer": "npm:@jsr/fiatjaf__promenade-trusted-dealer@^0.4.3",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.31.1",
    "nostr-tools": "^2.10.4",
    "qrcode": "^1.5.4",
    "svelte": "^5.38.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.lnbits.nostr.social",
    "productName": "Nostr Social",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "files": [
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "icon": "icon",
    "mac": {
      "target": "dmg",
      "artifactName": "Nostr-Social-macOS-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Nostr-Social-Windows-x64.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Nostr-Social-Linux-x86_64.${ext}"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/qrcode": "^1.5.6",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.3.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.7"
  }
}
